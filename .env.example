# ============================================
# BACKEND CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://evia:evia123@localhost:5432/evia_booking

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret (change in production!)
